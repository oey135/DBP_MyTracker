# ─────────────────────────────────────────────
# .env  —  로컬 개발용
# Railway 배포 시에는 Railway 대시보드 Variables에 직접 입력
# ─────────────────────────────────────────────

# MySQL 접속 정보 (Railway MySQL 사용 시 자동 주입됨)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=mytracker

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES=7d

# 서버 포트 (Railway는 자동 할당)
PORT=4000

# 허용할 프론트엔드 origin
# 로컬: http://localhost:5173
# 배포: https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:5173
